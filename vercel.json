{
  "version": 2,
  "builds": [
    {
      "src": "index.js",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 60,
        "includeFiles": [
          "public/**",
          "media/**",
          "routes/**",
          "routes/endpoints/**",
          "lib/**",
          "utils/**",
          "config/**",
          "config.js",
          "package.json",
          "package-lock.json"
        ],
        "bodyParser": {
          "sizeLimit": "500mb"
        }
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/index.js"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
